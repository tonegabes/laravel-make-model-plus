{
  "$schema": "https://getcomposer.org/schema.json",
  "name": "tonegabes/laravel-make-model-plus",
  "description": "Generate model, permissions enum, policy, tests, and Laravel Filament resource scaffolding.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.3",
    "illuminate/console": "^12.0|^13.0",
    "illuminate/filesystem": "^12.0|^13.0",
    "illuminate/support": "^12.0|^13.0",
    "filament/filament": "^5.0"
  },
  "require-dev": {
    "orchestra/testbench": "^10.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0"
  },
  "autoload": {
    "psr-4": {
      "Tonegabes\\LaravelMakeModelPlus\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tonegabes\\LaravelMakeModelPlus\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Tonegabes\\LaravelMakeModelPlus\\LaravelMakeModelPlusServiceProvider"
      ],
      "commands": [
        "Tonegabes\\LaravelMakeModelPlus\\Console\\MakeModelPlusCommand"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
