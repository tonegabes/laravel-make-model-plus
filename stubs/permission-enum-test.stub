<?php

declare(strict_types=1);

use {{ AppNamespace }}\Enums\Permissions\{{ EnumClass }};

it('has expected cases and string values', function (): void {
    expect({{ EnumClass }}::All->value)->toBe('{{ resource }}.*')
        ->and({{ EnumClass }}::ViewAny->value)->toBe('{{ resource }}.view.any')
        ->and({{ EnumClass }}::View->value)->toBe('{{ resource }}.view')
        ->and({{ EnumClass }}::Create->value)->toBe('{{ resource }}.create')
        ->and({{ EnumClass }}::Update->value)->toBe('{{ resource }}.update')
        ->and({{ EnumClass }}::Delete->value)->toBe('{{ resource }}.delete')
        ->and({{ EnumClass }}::Restore->value)->toBe('{{ resource }}.restore')
        ->and({{ EnumClass }}::ForceDelete->value)->toBe('{{ resource }}.force-delete')
        ->and({{ EnumClass }}::Replicate->value)->toBe('{{ resource }}.replicate')
        ->and({{ EnumClass }}::Reorder->value)->toBe('{{ resource }}.reorder');
});

it('has exactly ten cases', function (): void {
    expect({{ EnumClass }}::cases())->toHaveCount(10);
});
